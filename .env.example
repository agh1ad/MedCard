# PostgreSQL database used by the API server.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medcard

# Create a restricted project key at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Lowest-cost supported organizer. Override only after comparing real cards.
OPENAI_MODEL=gpt-5-nano

# Runtime values used by the Replit/Vite artifact processes.
PORT=5000
BASE_PATH=/
